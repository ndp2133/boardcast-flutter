{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude Code needs your input\" with title \"Boardcast Flutter\"'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(flutter test *)",
      "Bash(flutter build *)",
      "Bash(flutter pub *)",
      "Bash(dart format *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push origin *)"
    ]
  }
}
